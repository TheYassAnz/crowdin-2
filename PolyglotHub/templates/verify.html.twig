<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Email Verification</title>
</head>
<body>
    <h1>Verify Your Email Address</h1>

    <p>Hello {{ user.email }},</p>

    <p>Thank you for registering on our site. To complete your registration, please confirm your email address by clicking the button below:</p>

    <p>
        <a href="{{ path('app_verify_email', {'token': token}) }}" style="display: inline-block; padding: 10px 20px; font-size: 16px; font-weight: bold; background-color: #4CAF50; color: white; text-decoration: none; border-radius: 5px;">
            Verify Email
        </a>
    </p>

</body>
</html>
