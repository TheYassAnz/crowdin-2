{% extends 'base.html.twig' %}

{% block title %}New Message{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>New Message to {{ recipient.fullName }}</h1>

        {{ form_start(form) }}
        {{ form_widget(form) }}
        <button type="submit" class="btn btn-primary">Send</button>
        {{ form_end(form) }}
    </div>
{% endblock %}