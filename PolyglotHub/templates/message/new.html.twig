{% extends 'base.html.twig' %}

{% block title %}New Message{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="card">
            <div class="card-header">
                <h2>New Message {% if recipient %}to {{ recipient.firstname }} {{ recipient.lastname }}{% endif %}</h2>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                    {% if recipient is not defined or not recipient %}
                        <div class="mb-3">
                            {{ form_label(form.recipient) }}
                            {{ form_widget(form.recipient, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.recipient) }}
                        </div>
                    {% endif %}
                    <div class="mb-3">
                        {{ form_label(form.content) }}
                        {{ form_widget(form.content, {'attr': {'class': 'form-control', 'rows': 5}}) }}
                        {{ form_errors(form.content) }}
                    </div>
                    <div class="d-flex justify-content-between">
                        <a href="{{ path('app_messages') }}" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Send Message</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}