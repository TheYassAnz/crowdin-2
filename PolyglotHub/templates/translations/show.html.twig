{% extends 'base.html.twig' %}

{% block title %}Traduction
{% endblock %}

{% block body %}
	<style>
		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}

		.example-wrapper code {
			background: #F5F5F5;
			padding: 2px 6px;
		}
	</style>

	<div class="example-wrapper">
		{% if translation is not null %}
			<div class="d-flex justify-content-between my-5">
				<a href="{{ path('app_translations') }}" class="btn btn-secondary">Retour à la liste</a>
			</div>
			<div class="list-group">
				<div class="list-group-item">
					<div class="d-flex w-100 justify-content-between p-3">
						<div>
							<span class="me-3">{{ translation.source.content }}</span>
							<span>&rarr;</span>
							<span class="ms-3">{{ translation.getTranslatedContent() }}</span>
						</div>
						<small class="text-muted">Clé :
							{{ translation.source.cle }}</small>
					</div>
					<div class="d-flex w-100 justify-content-end px-3 mb-3">
						<ul class="list-unstyled">
							<li>
								<small class="text-muted">Langue source :
									{{ translation.source.project.getStartLanguage().name }}
								</small>
							</li>
							<li>
								<small class="text-muted">Langage cible :
									{{ translation.getTargetLanguage.name }}
								</small>
							</li>
						</ul>
					</div>
				</div>
			</div>
		{% else %}
			<div class="alert alert-warning text-center">Source inexistante</div>
		{% endif %}
	</div>

{% endblock %}
