{% extends 'base.html.twig' %}

{% block title %}Détails de la traduction{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .translation-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            padding: 2.5rem;
            margin: 2rem;
            max-width: 100%;
        }

        .translation-content {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 2rem;
            align-items: center;
            margin-bottom: 2rem;
            padding: 1.5rem;
            background: #f8f9fa;
            border-radius: 8px;
        }

        .language-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.9rem;
            color: #6c757d;
            background: #e9ecef;
            margin-bottom: 0.5rem;
        }

        .translation-text {
            font-size: 1.1rem;
            line-height: 1.6;
            padding: 1rem;
            background: white;
            border-radius: 6px;
            border: 1px solid #dee2e6;
        }

        .metadata {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px solid #dee2e6;
        }

        .metadata-item {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="translation-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a href="{{ path('app_translations') }}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Retour aux traductions
            </a>
        </div>

        {% if translation is not null %}
            <div class="translation-content">
                <div>
                    <div class="language-badge">
                        <i class="fas fa-globe-americas"></i>
                        {{ translation.source.project.getStartLanguage().name }}
                    </div>
                    <div class="translation-text">{{ translation.source.content }}</div>
                </div>
                
                <div class="text-center">
                    <i class="fas fa-arrow-right fa-lg text-muted"></i>
                </div>
                
                <div>
                    <div class="language-badge">
                        <i class="fas fa-globe-europe"></i>
                        {{ translation.getTargetLanguage.name }}
                    </div>
                    <div class="translation-text">{{ translation.getTranslatedContent() }}</div>
                </div>
            </div>

            <div class="metadata">
                <div class="metadata-item">
                    <span class="text-muted">
                        <i class="fas fa-key me-2"></i>Clé
                    </span>
                    <strong>{{ translation.source.cle }}</strong>
                </div>
                <div class="metadata-item">
                    <span class="text-muted">
                        <i class="fas fa-project-diagram me-2"></i>Projet
                    </span>
                    <strong>{{ translation.source.project.name }}</strong>
                </div>
                <div class="metadata-item">
                    <span class="text-muted">
                        <i class="fas fa-clock me-2"></i>Dernière mise à jour
                    </span>
                    <strong>{{ translation.updatedAt|date('d/m/Y H:i') }}</strong>
                </div>
            </div>
        {% else %}
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle me-2"></i>
                Cette traduction n'existe pas
            </div>
        {% endif %}
    </div>
{% endblock %}
