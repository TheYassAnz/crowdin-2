{% extends 'base.html.twig' %}

{% block title %}Proposer une traduction
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		document.addEventListener('DOMContentLoaded', function () {
const aiButton = document.querySelector('#ai-suggest-btn');
if (aiButton) {
aiButton.addEventListener('click', async function () {
try {
console.log('Getting AI suggestion...');
const sourceText = document.querySelector('#translation_content').value;
const targetLanguage = document.querySelector('#translation_language').value;

if (! sourceText || ! targetLanguage) {
console.error('Missing source text or target language');
return;
}

const response = await fetch('/api/ai/suggest', {
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify(
{text: sourceText, targetLanguage: targetLanguage}
)
});

const data = await response.json();
console.log('AI response:', data);

if (data.suggestion) {
document.querySelector('#translation_translated_content').value = data.suggestion;
}
} catch (error) {
console.error('Error:', error);
}
});
} else {
console.error('AI suggestion button not found');
}
});
	</script>
{% endblock %}

{% block body %}
	<style>
		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}

		.example-wrapper code {
			background: #F5F5F5;
			padding: 2px 6px;
		}
	</style>

	<div class="example-wrapper">
		<div class="w-50 mx-auto">
			<h1>Proposer une traduction</h1>

			{{ form_start(form) }}
			{{ form_widget(form) }}
			<p>{{ translation.source.project.name }}</p>
			<button type="submit" class="btn btn-primary">Envoyer</button>
			<button type="button" id="ai-suggest-btn" class="btn btn-secondary">
				<i class="fas fa-robot"></i>
				Get AI Suggestion
			</button>
			{{ form_end(form) }}
		</div>
	</div>
{% endblock %}
