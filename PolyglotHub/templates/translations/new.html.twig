{% extends 'base.html.twig' %}

{% block title %}Nouvelle Traduction
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .translation-form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        padding: 2.5rem;
        margin: 2rem;
        max-width: 100%;
    }

    .form-header {
        margin-bottom: 2rem;
        border-bottom: 1px solid #dee2e6;
        padding-bottom: 1rem;
    }

    .form-section {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-weight: 500;
        color: #495057;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-control {
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 0.75rem;
        transition: all 0.2s ease;
    }

    .form-control:focus {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }

    .btn-group {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn-primary,
    .btn-secondary {
        padding: 0.75rem 1.5rem;
        border-radius: 6px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .btn-primary:hover,
    .btn-secondary:hover {
        transform: translateY(-1px);
    }

    .loading-indicator {
        display: inline-block;
        margin-right: 0.5rem;
    }
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const aiButton = document.getElementById('ai-suggest-btn');
        const sourceSelect = document.querySelector('select[name="translation[source]"]');
        const targetLangSelect = document.querySelector('select[name="translation[target_language]"]');
        const translatedInput = document.querySelector('textarea[name="translation[translated_content]"]');

        if (aiButton && sourceSelect && targetLangSelect && translatedInput) {
            aiButton.addEventListener('click', async () => {
                if (!sourceSelect.value || !targetLangSelect.value) {
                    alert('Please select both source and target language');
                    return;
                }

                aiButton.disabled = true;
                aiButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Translating...';

                try {
                    const response = await fetch('{{ path("app_translations_suggest") }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            sourceId: sourceSelect.value,
                            targetLanguageId: targetLangSelect.value
                        })
                    });

                    if (!response.ok)
                        throw new Error('Translation failed');


                    const data = await response.json();
                    translatedInput.value = data.suggestion;

                } catch (error) {
                    console.error('Error:', error);
                    alert('Translation failed: ' + error.message);
                } finally {
                    aiButton.disabled = false;
                    aiButton.innerHTML = '<i class="fas fa-robot"></i> Get AI Suggestion';
                }
            });
        }
    });
</script>
{% endblock %}

{% block body %}
<div class="translation-form-card">
    <div class="form-header">
        <h2 class="mb-0">
            <i class="fas fa-language me-2"></i>
            Nouvelle Traduction
        </h2>
    </div>

    {{ form_start(form) }}
    <div class="form-section">
        <div class="mb-4">
            <label class="form-label">
                <i class="fas fa-file-alt me-2"></i>
                {{ form_label(form.source) }}
            </label>
            {{ form_widget(form.source, {
                    'attr': {
                        'class': 'form-control',
                        'placeholder': 'Sélectionnez le texte source'
                    }
                }) }}
            {{ form_errors(form.source) }}
        </div>

        <div class="mb-4">
            <label class="form-label">
                <i class="fas fa-globe me-2"></i>
                {{ form_label(form.target_language) }}
            </label>
            {{ form_widget(form.target_language, {
                    'attr': {
                        'class': 'form-control',
                        'placeholder': 'Choisissez la langue cible'
                    }
                }) }}
            {{ form_errors(form.target_language) }}
        </div>

        <div class="mb-4">
            <label class="form-label">
                <i class="fas fa-pen me-2"></i>
                {{ form_label(form.translated_content) }}
            </label>
            {{ form_widget(form.translated_content, {
                    'attr': {
                        'class': 'form-control',
                        'rows': 5,
                        'placeholder': 'Entrez votre traduction ici'
                    }
                }) }}
            {{ form_errors(form.translated_content) }}
        </div>
    </div>

    <div class="btn-group">
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save me-2"></i>
            Enregistrer
        </button>
        <button type="button" id="ai-suggest-btn" class="btn btn-secondary">
            <i class="fas fa-robot me-2"></i>
            Suggestion IA
        </button>
    </div>
    {{ form_end(form) }}
</div>
{% endblock %}