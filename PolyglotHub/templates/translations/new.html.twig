{% extends 'base.html.twig' %}

{% block title %}Proposer une traduction{% endblock %}

{% block body %}
<style>
    .example-wrapper {
        margin: 1em auto;
        max-width: 800px;
        width: 95%;
        font: 18px/1.5 sans-serif;
    }

    .example-wrapper code {
        background: #F5F5F5;
        padding: 2px 6px;
    }
</style>

<div class="example-wrapper">
    <div class="w-50 mx-auto">
        <h1>Proposer une traduction</h1>

        {{ form_start(form) }}
        {{ form_widget(form) }}
        <p>{{ translation.source.project.name }}</p>
        <button type="submit" class="btn btn-primary">Envoyer</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}