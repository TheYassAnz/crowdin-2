{% extends 'base.html.twig' %}

{% block title %}Proposer une traduction{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const aiButton = document.querySelector('#ai-suggest-btn');
            const sourceSelect = document.querySelector('#translation_source');
            const translatedInput = document.querySelector('#translation_translated_content');
            
            const targetLanguage = '{{ source.project.targetLanguage.code|default('en')|escape('js') }}';
            
            console.log('AI translation elements:', {
                aiButton: !!aiButton,
                sourceSelect: !!sourceSelect,
                translatedInput: !!translatedInput,
                targetLanguage: targetLanguage
            });

            if (aiButton && sourceSelect && translatedInput) {
                aiButton.addEventListener('click', async function() {
                    try {
                        const sourceOption = sourceSelect.options[sourceSelect.selectedIndex];
                        if (!sourceOption) {
                            throw new Error('Please select a source text');
                        }
                        
                        const sourceText = sourceOption.text;
                        if (!sourceText || !targetLanguage) {
                            throw new Error('Source text or target language missing');
                        }
                        
                        aiButton.disabled = true;
                        aiButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Translating...';
                        
                        const response = await fetch('/api/ai/suggest', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({
                                text: sourceText,
                                targetLanguage: targetLanguage
                            })
                        });
                        
                        if (!response.ok) {
                            throw new Error(`HTTP error! status: ${response.status}`);
                        }
                        
                        const data = await response.json();
                        if (data.suggestion) {
                            translatedInput.value = data.suggestion;
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        alert(error.message);
                    } finally {
                        aiButton.disabled = false;
                        aiButton.innerHTML = '<i class="fas fa-robot"></i> Get AI Suggestion';
                    }
                });
            } else {
                console.error('Required elements not found');
            }
        });
    </script>
{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="card">
            <div class="card-header">
                <h2>New Translation</h2>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_label(form.source) }}
                        {{ form_widget(form.source, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.source) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.translated_content) }}
                        {{ form_widget(form.translated_content, {'attr': {'class': 'form-control', 'rows': 5}}) }}
                        {{ form_errors(form.translated_content) }}
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Translation</button>
                        <button type="button" id="ai-suggest-btn" class="btn btn-secondary">
                            <i class="fas fa-robot"></i> Get AI Suggestion
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}