{% extends 'base.html.twig' %}

{% block title %}PROJECTS
{% endblock %}

{% block body %}
	<style>
		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}

		.example-wrapper code {
			background: #F5F5F5;
			padding: 2px 6px;
		}
	</style>


	<div class="example-wrapper">
		{% if project is not null %}
			<div class="d-flex justify-content-between my-5">
				<a href="{{ path('app_projects') }}" class="btn btn-secondary">Retour à la liste</a>
			</div>
			<div>
				<div class="card p-2">
					<div class="d-flex w-100 justify-content-between p-3">
						<h5 class="mb-1">{{ project.name }}</h5>
						<small class="text-muted">Identifiant :
							{{ project.id }}</small>
					</div>
					<div class="d-flex w-100 justify-content-between px-3 mb-3">
						<div>
							<ul>
								<li>
									<small class="text-muted">Langue d'origine :
										{{ project.getStartLanguage().getName() }}</small>
								</li>
								<li>
									<small class="text-muted">Langue cible :
										{{ project.getTargetLanguage().getName() }}</small>
								</li>
							</ul>
						</div>

						<div class="text-end">
							<div>
								<small class="text-muted">Propriétaire:
									{{ project.user.firstname }}
									{{ project.user.lastname }}</small>
							</div>
							{% if project.collaborator is not null %}
								<div>
									<small class="text-muted">
										Collaborateur :
										<a href="{{ path('app_profile_show', {id: project.collaborator.id}) }}">
											{{ project.collaborator.firstname }}
											{{ project.collaborator.lastname }}
										</a>
									</small>
								</div>
							{% endif %}
						</div>
					</div>
				</div>
				<div class="mt-3">
					<div class="d-flex justify-content-between fs-5">
						<span>Sources liées:</span>
						<a href="{{ path('app_sources_new', {projectId: project.id}) }}" class="btn btn-dark align-self-start">
							<i class="fa fa-plus"></i>
						</a>
					</div>
					<hr/>
					<div>
						<ul class="list-group">
							{% for source in project.sources %}
								<a href="{{ path('app_sources_show', {id: source.id}) }}" class="list-group-item list-group-item-action">
									<small>{{ source.cle }}</small>
									-
									<small>{{ source.content }}</small>
								</a>
							{% else %}
								<li class="list-group-item">Aucune source disponible</li>
							{% endfor %}
						</ul>
					</div>
				</div>
			</div>
		{% else %}
			<div class="alert alert-warning text-center">Projet inexistant</div>
		{% endif %}
	</div>
{% endblock %}
