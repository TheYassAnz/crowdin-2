{% extends 'base.html.twig' %}

{% block title %}PROJECTS{% endblock %}

{% block body %}
<style>
    .example-wrapper {
        margin: 1em auto;
        max-width: 800px;
        width: 95%;
        font: 18px/1.5 sans-serif;
    }

    .example-wrapper code {
        background: #F5F5F5;
        padding: 2px 6px;
    }
</style>

<div class="example-wrapper">
    {% if project is not null %}
    <div class="d-flex justify-content-between my-5">
        <a href="{{ path('app_projects') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>
    <div class="list-group">
        <div class="list-group-item list-group-item-action">
            <div class="d-flex w-100 justify-content-between p-3">
                <h5 class="mb-1">{{ project.name }}</h5>
                <small class="text-muted">Identifiant : {{ project.id }}</small>
            </div>
            <div class="d-flex w-100 justify-content-between px-3 mb-3">
                <div>
                    <ul>
                        <li><small class="text-muted">Langue d'origine : {{ project.getStartLanguage().getName() }}</small></li>
                        <li><small class="text-muted">Langue cible : {{ project.getTargetLanguage().getName() }}</small></li>
                    </ul>
                </div>

                <small class="text-muted">Créé par : {{ project.user.email }}</small>
            </div>
        </div>
    </div>
    {% else %}
    <div class="alert alert-warning text-center">Projet inexistant</div>
    {% endif %}
</div>

{% endblock %}