{% extends 'base.html.twig' %}

{% block title %}SOURCES{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <div class="d-flex justify-content-between my-5">
        <a href="{{ path('app_sources_new') }}" class="btn btn-primary">Créer une source</a>
    </div>
    <h1>Liste des sources: </h1>
    <div class="list-group">
        {% for source in sources %}
        <a href="{{ path('app_sources_show', {id: source.id}) }}" class="list-group-item list-group-item-action">
            <div class="d-flex w-100 justify-content-between p-3">
                <h5 class="mb-1">{{ source.content }}</h5>
                <small class="text-muted">Clé: {{ source.cle }}</small>
            </div>
            <div class="d-flex w-100 justify-content-between px-3 mb-3">
                <small class="text-muted">Lié au projet: {{ source.project.name }}</small>
                

            </div>
        </a>
        {% endfor %}
    </div>
</div>
{% endblock %}
