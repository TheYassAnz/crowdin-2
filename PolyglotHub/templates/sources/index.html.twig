{% extends 'base.html.twig' %}

{% block title %}Sources{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .list-item {
            position: relative;
            transition: all 0.3s ease;
        }
        
        .action-buttons {
            position: absolute;
            right: -100px;
            top: 50%;
            transform: translateY(-50%);
            background: #f8f9fa;
            padding: 0.5rem;
            border-radius: 4px;
            box-shadow: -2px 0 5px rgba(0,0,0,0.1);
            transition: right 0.3s ease;
            display: flex;
            gap: 0.5rem;
        }
        
        .list-group-item:hover .action-buttons {
            right: 1rem;
        }
        
        .list-group-item {
            overflow: hidden;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Sources</h1>
    
    <div class="mb-3">
        <a href="{{ path('app_sources_new') }}" class="btn btn-primary">Create New</a>
        <a href="{{ path('app_sources_import_csv') }}" class="btn btn-success">Import CSV</a>
        <a href="{{ path('app_sources_export_csv') }}" class="btn btn-info">Export CSV</a>
    </div>

    <div class="list-group">
        {% for source in sources %}
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <a href="{{ path('app_sources_show', {id: source.id}) }}" class="text-decoration-none">
                            <h5 class="mb-1">{{ source.content }}</h5>
                        </a>
                        <div>
                            <small class="text-muted">Project: {{ source.project.name }}</small><br>
                            <small class="text-muted">Created by: {{ source.project.user.email }}</small>
                        </div>
                    </div>
                    
                    <div class="action-buttons">
                        <a href="{{ path('app_sources_show', {id: source.id}) }}" class="btn btn-info btn-sm">
                            <i class="fas fa-eye"></i>
                        </a>
                        {% if source.project.user == app.user %}
                            <a href="{{ path('app_sources_export_csv') }}" class="btn btn-success btn-sm">
                                <i class="fas fa-file-export"></i>
                            </a>
                            <a href="#" class="btn btn-warning btn-sm">
                                <i class="fas fa-edit"></i>
                            </a>
                            <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal{{ source.id }}">
                                <i class="fas fa-trash"></i>
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
            
            {% if source.project.user == app.user %}
                <!-- Delete Modal -->
                <div class="modal fade" id="deleteModal{{ source.id }}" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirm Delete</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                Are you sure you want to delete this source?
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <form action="{{ path('app_sources_delete', {id: source.id}) }}" method="post" style="display: inline-block">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ source.id) }}">
                                    <button type="submit" class="btn btn-danger">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}
        {% else %}
            <div class="alert alert-info">No sources found.</div>
        {% endfor %}
    </div>
</div>
{% endblock %}
