{% extends 'base.html.twig' %}

{% block title %}Sources
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<style>
		.list-group-item {
			position: relative;
			overflow: hidden;
			padding: 1.5rem;
		}

		.action-buttons {
			position: absolute;
			right: -150px;
			top: 50%;
			transform: translateY(-50%);
			display: flex;
			gap: 0.5rem;
			padding: 0.5rem;
		}

		.list-group-item:hover {
			background-color: #f8f9fa;
		}

		.project-content {
			transition: transform 0.3s ease;
		}

		.list-group-item:hover .project-content {
			transform: translateX(-100px);
		}

		hr {
			margin: 1rem 0;
			opacity: 0.1;
		}
	</style>
{% endblock %}

{% block body %}
	<div class="container mt-4">
		<div class="d-flex flex-row justify-content-between align-items-center mb-4">
			<h1>Sources</h1>

			<div class="d-flex gap-2">
				<a href="{{ path('app_sources_new') }}" class="btn btn-dark">
					<i class="fas fa-plus-circle"></i>
					Ajouter une source
				</a>
				<a href="{{ path('app_sources_import_csv') }}" class="btn btn-dark">
					<i class="fas fa-file-import"></i>
					Importer un fichier CSV
				</a>
			</div>
		</div>

		<div class="list-group">
			{% for source in sources %}
				<div class="list-group-item">
					<div class="d-flex justify-content-between align-items-center">
						<div>
							<h5 class="mb-1">{{ source.content }}</h5>
							<div>
								<small class="text-muted">Source lié au projet:
									{{ source.project.name }}</small><br>
								<small class="text-muted">Propriétaire:
									{{ source.project.user.email }}</small>
							</div>
						</div>

						<div class="action-buttons">
							<a href="{{ path('app_sources_show', {id: source.id}) }}" class="btn btn-info btn-sm">
								<i class="fas fa-eye"></i>
							</a>
							{% if source.project.user == app.user %}
								<a href="{{ path('app_sources_export_csv') }}" class="btn btn-success btn-sm">
									<i class="fas fa-file-export"></i>
								</a>
								<a href="#" class="btn btn-warning btn-sm">
									<i class="fas fa-edit"></i>
								</a>
								<button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal{{ source.id }}">
									<i class="fas fa-trash"></i>
								</button>
							{% endif %}
						</div>
					</div>
				</div>
				{% if not loop.last %}
					<hr>
				{% endif %}
				{% if source.project.user == app.user %}
					<!-- Delete Modal -->
					<div class="modal fade" id="deleteModal{{ source.id }}" tabindex="-1">
						<div class="modal-dialog">
							<div class="modal-content">
								<div class="modal-header">
									<h5 class="modal-title">Confirm Delete</h5>
									<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
								</div>
								<div class="modal-body">
									Are you sure you want to delete this source?
								</div>
								<div class="modal-footer">
									<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
									<form action="{{ path('app_sources_delete', {id: source.id}) }}" method="post" style="display: inline-block">
										<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ source.id) }}">
										<button type="submit" class="btn btn-danger">Delete</button>
									</form>
								</div>
							</div>
						</div>
					</div>
				{% endif %}
			{% else %}
				<div class="alert alert-dark">No sources found.</div>
			{% endfor %}
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
	<script>
		document.addEventListener('DOMContentLoaded', () => { // Initial animation
gsap.from('.list-group-item', {
duration: 0.5,
opacity: 0,
y: 50,
stagger: 0.1,
ease: 'power2.out'
});

// Hover animations
document.querySelectorAll('.list-group-item').forEach(item => {
const buttons = item.querySelector('.action-buttons');
const timeline = gsap.timeline({paused: true});

timeline.to(buttons, {
duration: 0.3,
right: '1rem',
ease: 'power2.out'
}).from(buttons.children, {
duration: 0.2,
opacity: 0,
x: 20,
stagger: 0.05,
ease: 'power2.out'
}, '-=0.1');

item.addEventListener('mouseenter', () => timeline.play());
item.addEventListener('mouseleave', () => timeline.reverse());
});
});
	</script>
{% endblock %}
