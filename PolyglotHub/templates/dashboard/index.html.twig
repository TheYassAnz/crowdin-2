{% extends 'base.html.twig' %}

{% block title %}Dashboard
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<style>
		.chart-container {
			position: relative;
			height: 300px;
			width: 100%;
		}
	</style>
{% endblock %}

{% block body %}
	<div class="container mt-4">
		<h1>
			<i class="fas fa-chart-line me-1"></i>
			Dashboard
		</h1>
        <hr>

		<div class="row mt-4">
			<div class="col-md-6 mb-4">
				<div class="card">
					<div class="card-header">Projects by Language</div>
					<div class="card-body">
						<canvas id="projectsChart"></canvas>
					</div>
				</div>
			</div>

			<div class="col-md-6 mb-4">
				<div class="card">
					<div class="card-header">Sources Distribution</div>
					<div class="card-body">
						<canvas id="sourcesChart"></canvas>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
	<script>
		document.addEventListener('DOMContentLoaded', () => {
try { // Debug
console.log('Data:', {
projects: {{ projectStats|json_encode|raw }},
sources: {{ sourceStats|json_encode|raw }}
});

// Get contexts
const projectsCtx = document.getElementById('projectsChart') ?. getContext('2d');
const sourcesCtx = document.getElementById('sourcesChart') ?. getContext('2d');

if (projectsCtx) {
new Chart(projectsCtx, {
type: 'bar',
data: {
labels: {{ projectStats.labels|json_encode|raw }},
datasets: [
{
label: 'Projects by Language',
data: {{ projectStats.data|json_encode|raw }},
backgroundColor: 'rgba(54, 162, 235, 0.5)'
}
]
},
options: {
responsive: true,
maintainAspectRatio: false
}
});
}

if (sourcesCtx) {
new Chart(sourcesCtx, {
type: 'pie',
data: {
labels: {{ sourceStats.labels|json_encode|raw }},
datasets: [
{
data: {{ sourceStats.data|json_encode|raw }},
backgroundColor: ['rgba(255, 99, 132, 0.5)', 'rgba(54, 162, 235, 0.5)', 'rgba(255, 206, 86, 0.5)']
}
]
},
options: {
responsive: true,
maintainAspectRatio: false
}
});
}
} catch (error) {
console.error('Chart initialization error:', error);
}
});
	</script>
{% endblock %}
