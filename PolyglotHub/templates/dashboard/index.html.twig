{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Dashboard</h1>
    
    <div class="row mt-4">
        <!-- Projects Bar Chart -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    Projects by Language
                </div>
                <div class="card-body">
                    <canvas id="projectsChart"></canvas>
                </div>
            </div>
        </div>
        
        <!-- Sources Pie Chart -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    Sources Distribution
                </div>
                <div class="card-body">
                    <canvas id="sourcesChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Translations Line Chart -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    Translation Progress Over Time
                </div>
                <div class="card-body">
                    <canvas id="translationsChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Languages Doughnut Chart -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    Target Languages Distribution
                </div>
                <div class="card-body">
                    <canvas id="languagesChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script type="module">
    import Chart from 'chart.js/auto';
    
    // Projects Bar Chart
    new Chart(document.getElementById('projectsChart'), {
        type: 'bar',
        data: {
            labels: {{ projectStats.labels|json_encode|raw }},
            datasets: [{
                label: 'Projects by Language',
                data: {{ projectStats.data|json_encode|raw }},
                backgroundColor: 'rgba(54, 162, 235, 0.5)',
                borderColor: 'rgba(54, 162, 235, 1)',
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'top',
                }
            }
        }
    });
    
    // Sources Pie Chart
    new Chart(document.getElementById('sourcesChart'), {
        type: 'pie',
        data: {
            labels: {{ sourceStats.labels|json_encode|raw }},
            datasets: [{
                data: {{ sourceStats.data|json_encode|raw }},
                backgroundColor: [
                    'rgba(255, 99, 132, 0.5)',
                    'rgba(54, 162, 235, 0.5)',
                    'rgba(255, 206, 86, 0.5)',
                    'rgba(75, 192, 192, 0.5)',
                    'rgba(153, 102, 255, 0.5)'
                ]
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'top',
                }
            }
        }
    });

    // Translations Line Chart
    new Chart(document.getElementById('translationsChart'), {
        type: 'line',
        data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
            datasets: [{
                label: 'Completed Translations',
                data: [12, 19, 3, 5, 2, 3],
                borderColor: 'rgba(75, 192, 192, 1)',
                tension: 0.1
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'top',
                }
            },
            scales: {
                y: {
                    beginAtZero: true
                }
            }
        }
    });

    // Languages Doughnut Chart
    new Chart(document.getElementById('languagesChart'), {
        type: 'doughnut',
        data: {
            labels: ['French', 'English', 'Spanish', 'German', 'Italian'],
            datasets: [{
                data: [30, 25, 20, 15, 10],
                backgroundColor: [
                    'rgba(255, 99, 132, 0.5)',
                    'rgba(54, 162, 235, 0.5)',
                    'rgba(255, 206, 86, 0.5)',
                    'rgba(75, 192, 192, 0.5)',
                    'rgba(153, 102, 255, 0.5)'
                ],
                borderColor: [
                    'rgba(255, 99, 132, 1)',
                    'rgba(54, 162, 235, 1)',
                    'rgba(255, 206, 86, 1)',
                    'rgba(75, 192, 192, 1)',
                    'rgba(153, 102, 255, 1)'
                ],
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'top',
                }
            }
        }
    });
</script>
{% endblock %}
