{% extends 'emails/base.html.twig' %}

{% block body %}
    <h1>New Source Added</h1>
    <p>Hello {{ user.email }},</p>
    
    <p>A new source has been added to your project "{{ project.name }}".</p>
    
    <p>Source Details:</p>
    <ul>
        <li>Key: {{ source.key }}</li>
        <li>Content: {{ source.content }}</li>
        <li>Created at: {{ source.getCreateDate()|date('Y-m-d H:i:s') }}</li>
    </ul>
    
    <p>Best regards,<br>Your Crowdin Team</p>
{% endblock %}