{% extends 'emails/base.html.twig' %}

{% block body %}
    <h1>New Project Created</h1>
    <p>Hello {{ user.email }},</p>
    
    <p>Your new project "{{ project.name }}" has been successfully created.</p>
    
    <p>Project Details:</p>
    <ul>
        <li>Start Language: {{ project.getStartLanguage().getName() }}</li>
        <li>Target Language: {{ project.getTargetLanguage().getName() }}</li>
        <li>Created at: {{ project.getCreateDate()|date('Y-m-d H:i:s') }}</li>
    </ul>
    
    <p>Best regards,<br>Your Crowdin Team</p>
{% endblock %}