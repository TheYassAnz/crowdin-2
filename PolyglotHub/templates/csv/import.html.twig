{% extends 'base.html.twig' %}

{% block title %}Import Csv{% endblock %}

{% block body %}
    <div class="example-wrapper">
        <style>
            .example-wrapper {
                margin: 1em auto;
                max-width: 800px;
                width: 95%;
                font: 18px/1.5 sans-serif;
            }
            .example-wrapper code {
                background: #F5F5F5;
                padding: 2px 6px;
            }
        </style>

        {{ form(form) }}

        {% if data is not empty %}
            <table>
                {% for row in data %}
                    <tr>
                        {% for cell in row %}
                            <td>{{ cell }}</td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </table>
        {% endif %}
    </div>
{% endblock %}
